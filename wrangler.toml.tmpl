name = "freepieces"
main = "src/worker.ts"
compatibility_date = "2026-04-14"
compatibility_flags = ["nodejs_compat"]

[vars]
# Public URL for building OAuth callback URLs.
# Value is read from .env (gitignored) via wrangler's ${} interpolation.
FREEPIECES_PUBLIC_URL = "${FREEPIECES_PUBLIC_URL}"

# KV namespace for encrypted per-user OAuth token storage.
# Canonical binding name: FREEPIECES_TOKEN_STORE (also accepted: FP_TOKEN_STORE, TOKEN_STORE).
# FREEPIECES_TOKEN_STORE_ID is read from .env (gitignored).
[[kv_namespaces]]
binding = "FREEPIECES_TOKEN_STORE"
id = "${FREEPIECES_TOKEN_STORE_ID}"

# KV namespace for OpenAuth session/token storage.
# Canonical binding name: FREEPIECES_AUTH_STORE (also accepted: FP_AUTH_STORE, AUTH_STORE).
# FREEPIECES_AUTH_STORE_ID is read from .env (gitignored).
[[kv_namespaces]]
binding = "FREEPIECES_AUTH_STORE"
id = "${FREEPIECES_AUTH_STORE_ID}"

# Cloudflare Email Workers – send verification codes.
# Canonical binding name: FREEPIECES_EMAIL (also accepted: FP_EMAIL, EMAIL).
# Requires Email Routing enabled on the domain.
[[send_email]]
name = "FREEPIECES_EMAIL"

# Static assets – the compiled admin React SPA.
# Build with: npm run build:admin
[assets]
directory = "./dist/public"
binding = "ASSETS"

# Static credentials are stored as Cloudflare Secrets (never in vars).
# Each variable resolves: FREEPIECES_<NAME> → FP_<NAME> → <NAME> (legacy).
# Use the FREEPIECES_ canonical form for new deployments.
#
#   wrangler secret put FREEPIECES_TOKEN_ENCRYPTION_KEY   # 32 random hex bytes → AES-GCM key material
#   (also accepted: FP_TOKEN_ENCRYPTION_KEY, TOKEN_ENCRYPTION_KEY)
#
# Gmail OAuth2 credentials:
#   wrangler secret put FREEPIECES_GMAIL_CLIENT_ID
#   wrangler secret put FREEPIECES_GMAIL_CLIENT_SECRET
#
# Example OAuth2 piece credentials:
#   wrangler secret put FREEPIECES_EXAMPLE_OAUTH_CLIENT_ID
#   wrangler secret put FREEPIECES_EXAMPLE_OAUTH_CLIENT_SECRET
#
# Admin UI credentials (set in .env for local dev, secrets for production):
#   wrangler secret put FREEPIECES_ADMIN_EMAILS     # comma-separated admin email list
#   wrangler secret put FREEPIECES_ALLOWED_EMAILS   # comma-separated allowed (non-admin) email list
#   (also accepted: FP_ADMIN_EMAILS / ADMIN_EMAILS, etc.)
#
# OpenAuth provider credentials (optional — social logins enabled when set):
#   wrangler secret put FREEPIECES_GOOGLE_CLIENT_ID
#   wrangler secret put FREEPIECES_GOOGLE_CLIENT_SECRET
#   wrangler secret put FREEPIECES_GITHUB_CLIENT_ID
#   wrangler secret put FREEPIECES_GITHUB_CLIENT_SECRET
#
# Verification email sender address (set in [vars] or as secret):
#   FREEPIECES_AUTH_SENDER_EMAIL = "noreply@yourdomain.com"
#   (also accepted: FP_AUTH_SENDER_EMAIL, AUTH_SENDER_EMAIL)
#
# Runtime API key (recommended):
#   wrangler secret put FREEPIECES_RUN_API_KEY     # prefix with fp_sk_, e.g. fp_sk_<hex32>
#   (also accepted: FP_RUN_API_KEY, RUN_API_KEY)
# When set, runtime callers use:
#   Authorization: Bearer <FREEPIECES_RUN_API_KEY>
#   X-User-Id: <userId>
#   X-Piece-Token: <token>

# ── Queue delivery for subscriptions ──────────────────────────────────────────
# To deliver webhook subscription events to a Cloudflare Queue instead of an
# HTTP callback, add a [[queues.producers]] entry for each target queue.
# Binding naming convention: QUEUE_<UPPER_SNAKE_CASE_OF_QUEUE_NAME>
#
# [[queues.producers]]
# queue = "slack-new-message"
# binding = "QUEUE_SLACK_NEW_MESSAGE"
