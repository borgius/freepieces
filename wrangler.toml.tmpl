name = "freepieces"
main = "src/worker.ts"
compatibility_date = "2026-04-14"
compatibility_flags = ["nodejs_compat"]

[vars]
# Public URL for building OAuth callback URLs.
# Value is read from .env (gitignored) via wrangler's ${} interpolation.
FREEPIECES_PUBLIC_URL = "${FREEPIECES_PUBLIC_URL}"

# KV namespace for encrypted per-user OAuth token storage.
# TOKEN_STORE_ID is read from .env (gitignored).
[[kv_namespaces]]
binding = "TOKEN_STORE"
id = "${TOKEN_STORE_ID}"

# Static assets – the compiled admin React SPA.
# Build with: npm run build:admin
[assets]
directory = "./dist/public"
binding = "ASSETS"

# Static credentials are stored as Cloudflare Secrets (never in vars):
#   wrangler secret put OAUTH_CLIENT_ID
#   wrangler secret put OAUTH_CLIENT_SECRET
#   wrangler secret put TOKEN_ENCRYPTION_KEY   # 32 random hex bytes → AES-GCM key material
#
# Gmail OAuth2 credentials:
#   wrangler secret put GMAIL_CLIENT_ID
#   wrangler secret put GMAIL_CLIENT_SECRET
#
# Admin UI credentials (set in .env for local dev, secrets for production):
#   wrangler secret put ADMIN_USER
#   wrangler secret put ADMIN_PASSWORD
#   wrangler secret put ADMIN_SIGNING_KEY      # 32 random hex bytes → openssl rand -hex 32
