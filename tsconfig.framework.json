{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/framework",
    "rootDir": "src/framework",
    "types": ["node", "@cloudflare/workers-types"],
    "skipLibCheck": true
  },
  "include": ["src/framework"],
  "exclude": ["src/framework/**/*.test.ts"]
}
